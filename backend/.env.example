# PhishGuard AI Backend Configuration

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=your-secret-key-here
PORT=5000


# PhishTank Configuration
# Sign up at https://www.phishtank.com/api.php to get your API key
PHISHTANK_API_KEY=your-phishtank-api-key-here
PHISHTANK_LOCAL_DB=phishtank.csv

# ML Model
MODEL_PATH=phish_model.joblib

# Database
DATABASE_URL=sqlite:///phish_guard.db
