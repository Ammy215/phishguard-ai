{
  "manifest_version": 3,
  "name": "PhishGuard AI - Phishing Detector",
  "description": "Detect phishing websites in real-time using ML + heuristic analysis",
  "version": "3.0",

  "permissions": [
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  }
}