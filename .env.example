# PhishGuard AI - Environment Configuration

# Flask Configuration
FLASK_DEBUG=true
PORT=5000
CORS_ORIGINS=*

# ML Model Path
MODEL_PATH=phish_model.joblib

# Google Safe Browsing API
GOOGLE_SAFE_BROWSING_API_KEY=

# PhishTank Configuration
PHISHTANK_API_KEY=
PHISHTANK_LOCAL_DB=

# URLHaus Configuration
URLHAUS_API_KEY=

# Optional: Local threat feed cache directory
THREAT_FEED_CACHE_DIR=./cache
